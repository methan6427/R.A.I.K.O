# R.A.I.K.O Docker Deployment Configuration
# Copy this file to .env and update the values for your deployment

# ─── Database Configuration ───────────────────────────────────────────────────
# PostgreSQL database name
POSTGRES_DB=raiko

# PostgreSQL username
POSTGRES_USER=raiko

# PostgreSQL password (CHANGE THIS IN PRODUCTION!)
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=raiko_secure_password

# PostgreSQL port (internal: 5432, exposed: 5432)
POSTGRES_PORT=5432

# ─── Server Configuration ─────────────────────────────────────────────────────
# Port to expose the R.A.I.K.O backend API
RAIKO_PORT=8080

# ─── Security ─────────────────────────────────────────────────────────────────
# Authentication token for API access and WebSocket connections
# Generate a strong token: openssl rand -base64 32
# This token must be configured in mobile/desktop apps to authenticate
RAIKO_AUTH_TOKEN=change-me-in-production

# ─── Database SSL Configuration ───────────────────────────────────────────────
# Set to 'require' if database is over public internet
# Options: disable, allow, prefer, require
RAIKO_DATABASE_SSL_MODE=disable

# ─── TTS Voice Configuration ──────────────────────────────────────────────────
# Piper voice model to use for text-to-speech
# Available: en_US-ryan-high (default, high quality)
# To add more voices, download .onnx files to piper/voices/ directory
PIPER_VOICE_MODEL=en_US-ryan-high

# ─── Deployment Notes ─────────────────────────────────────────────────────────
# Production Deployment Checklist:
# 1. Generate strong passwords:
#    POSTGRES_PASSWORD=$(openssl rand -base64 32)
#    RAIKO_AUTH_TOKEN=$(openssl rand -base64 32)
#
# 2. Set RAIKO_DATABASE_SSL_MODE=require if DB is on public network
#
# 3. Configure mobile app with:
#    - Backend HTTP URL: http://your-domain:8080
#    - WebSocket URL: ws://your-domain:8080
#    - Auth Token: (same RAIKO_AUTH_TOKEN)
#
# 4. Use a reverse proxy (nginx, Caddy, Traefik) in front:
#    - Handle HTTPS/TLS termination
#    - Load balancing
#    - Rate limiting
#
# 5. Monitor logs:
#    docker-compose logs -f backend
#
# 6. Database backups:
#    docker-compose exec postgres pg_dump -U raiko raiko > backup.sql
